# Concept2 Exporter Configuration
# Copy this file to .env and update with your values

# Concept2 API Token (REQUIRED)
# Get your token from: https://log.concept2.com/user/settings
CONCEPT2_API_TOKEN=your-api-token-here

# How often to poll Concept2 API for new workouts, in seconds (optional, default: 3600)
# Examples: 1800 (30 min), 3600 (1 hour), 7200 (2 hours)
CONCEPT2_POLL_INTERVAL_SECONDS=3600

# Logging level: DEBUG, INFO, WARNING, ERROR (optional, default: INFO)
CONCEPT2_LOG_LEVEL=INFO

# Path to persist sync state and workout cache (optional, default: /data/state.json)
# In Docker, this should stay as /data since that's the mounted volume
CONCEPT2_STATE_FILE=/data/state.json

# InfluxDB v2 Configuration (optional)
# If not set, metrics will only be exported via Prometheus endpoint
# Get your token from InfluxDB UI: Settings > Tokens
CONCEPT2_INFLUX_URL=http://localhost:8086
CONCEPT2_INFLUX_ORG=my-org
CONCEPT2_INFLUX_BUCKET=concept2
CONCEPT2_INFLUX_TOKEN=your-influxdb-token-here
